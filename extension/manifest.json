{
  "manifest_version": 3,
  "name": "LyricsOverlay Bridge",
  "version": "4.5",
  "description": "Seamlessly syncs YouTube, Lrclib, Legato, and Musixmatch lyrics to your local C# LyricsOverlay app.",
  "permissions": [
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://translate.googleapis.com/*",
    "*://lrclib.net/*",
    "*://lyrics-api.boidu.dev/*",
    "*://lyrics.api.dacubeking.com/*",
    "http://localhost:7331/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src 'self' https://lyrics.api.dacubeking.com;"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}